// Prisma schema for multi-tenant POS system

generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =========================
//         ENUMS
// =========================
enum Role {
  ADMIN
  MANAGER
  CASHIER
}

// =========================
//        MODELS
// =========================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  subdomain String   @unique
  settings  Json?
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  branches      Branch[]
  products      Product[]
  categories    ProductCategory[]
  suppliers     TenantsOnSuppliers[]
  sales         Sale[]
  purchases     Purchase[]
  inventories   Inventory[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  auditLogs     AuditLog[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String
  password  String
  name      String
  role      Role     @default(CASHIER)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  branchId    Int
  branch      Branch @relation("UserBranch", fields: [branchId], references: [id])
  createdById Int?
  createdBy   User?  @relation("CreatedUsers", fields: [createdById], references: [id])

  sales                    Sale[]            @relation("Salesperson")
  createdUsers             User[]            @relation("CreatedUsers")
  createdBranches          Branch[]          @relation("CreatedBranches")
  createdProductCategories ProductCategory[] @relation("CreatedProductCategories")
  createdProducts          Product[]         @relation("CreatedProducts")
  createdInventories       Inventory[]       @relation("CreatedInventories")
  createdSales             Sale[]            @relation("CreatedSales")
  createdSuppliers         Supplier[]        @relation("CreatedSuppliers")
  createdPurchases         Purchase[]        @relation("CreatedPurchases")
  auditLogs                AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  tenantId  String
  userId    Int
  action    String
  details   Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  tag       String
  location  String?
  active    Boolean  @default(true)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  createdById Int?
  createdBy   User?  @relation("CreatedBranches", fields: [createdById], references: [id])

  users     User[]      @relation("UserBranch")
  inventory Inventory[]
  sales     Sale[]
  purchases Purchase[]

  @@unique([tenantId, name])
  @@unique([tenantId, tag])
  @@index([tenantId])
}

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  active      Boolean  @default(true)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  createdById Int
  createdBy   User   @relation("CreatedProductCategories", fields: [createdById], references: [id])

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id                Int             @id @default(autoincrement())
  name              String
  code              String
  unit              String
  price             Float
  active            Boolean         @default(true)
  deleted           Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  productCategoryId Int
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id])
  createdById       Int
  createdBy         User            @relation("CreatedProducts", fields: [createdById], references: [id])
  inventory         Inventory[]
  saleItems         SaleItem[]
  purchaseItems     PurchaseItem[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
}

model Inventory {
  id           Int      @id @default(autoincrement())
  stock        Int
  reorderLevel Int      @default(10)
  deleted      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  branchId     Int
  branch       Branch   @relation(fields: [branchId], references: [id])
  createdById  Int
  createdBy    User     @relation("CreatedInventories", fields: [createdById], references: [id])

  @@unique([tenantId, productId, branchId])
  @@index([tenantId])
}

model Sale {
  id          Int        @id @default(autoincrement())
  invoice     String     @unique
  total       Float
  discount    Float?     @default(0)
  paymentType String
  datetime    DateTime
  status      String     @default("completed")
  deleted     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  userId      Int
  user        User       @relation("Salesperson", fields: [userId], references: [id])
  branchId    Int
  branch      Branch     @relation(fields: [branchId], references: [id])
  createdById Int
  createdBy   User       @relation("CreatedSales", fields: [createdById], references: [id])
  items       SaleItem[]

  @@index([tenantId])
  @@index([datetime])
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Float
  discount  Float?  @default(0)
  tax       Float?  @default(0)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, saleId, productId])
  @@index([tenantId])
}

model Supplier {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  contact     String?              @unique
  email       String?              @unique
  address     String?
  active      Boolean              @default(true)
  deleted     Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdById Int?
  createdBy   User?                @relation("CreatedSuppliers", fields: [createdById], references: [id])
  tenants     TenantsOnSuppliers[]
  purchases   Purchase[]
}

model TenantsOnSuppliers {
  assignedAt DateTime @default(now())
  assignedBy String
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@id([tenantId, supplierId])
}

model Purchase {
  id          Int            @id @default(autoincrement())
  poNumber    String         @unique
  datetime    DateTime
  total       Float          @default(0)
  status      String         @default("completed")
  deleted     Boolean        @default(false)
  createdAt   DateTime       @default(now())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  supplierId  Int
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  branchId    Int
  branch      Branch         @relation(fields: [branchId], references: [id])
  createdById Int
  createdBy   User           @relation("CreatedPurchases", fields: [createdById], references: [id])
  items       PurchaseItem[]

  @@index([tenantId])
  @@index([datetime])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  quantity   Int
  price      Float?   @default(0)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([tenantId, purchaseId, productId])
  @@index([tenantId])
}
