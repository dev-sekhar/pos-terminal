# This is the global options block.
{
    # This is the critical fix.
    # It forces Caddy to bind its listeners to the 127.0.0.1 IP address,
    # which is what lvh.me and all its subdomains resolve to.
    default_bind 127.0.0.1
}

# Caddy will now listen specifically on 127.0.0.1:8080 for these hosts.
http://lvh.me:8080, http://*.lvh.me:8080 {
    # Optional but recommended: keep the access log for debugging.
    log {
        output stdout
        format console
    }

    # API requests are proxied to your backend on port 3000
    handle /api/* {
        reverse_proxy 127.0.0.1:3000
    }

    # All other requests are proxied to your frontend on port 5173
    handle {
        reverse_proxy 127.0.0.1:5173
    }
}